{
  "name": "@karamem0/commistant",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "start": "tsc && vite",
    "build": "tsc -b && vite build",
    "eslint": "eslint src",
    "eslint:fix": "eslint src --fix",
    "stylelint": "stylelint 'src/**/*.{css,scss,jsx,tsx}'",
    "stylelint:fix": "stylelint 'src/**/*.{css,scss,jsx,tsx}' --fix",
    "formatjs:extract": "formatjs extract src/**/messages.ts --out-file src/translations/ja.json --id-interpolation-pattern [sha512:contenthash:base64:6] --format simple",
    "formatjs:compile": "formatjs compile src/translations/ja.json --out-file src/translations/compiled/ja.json --ast --format simple"
  },
  "dependencies": {
    "@automapper/pojos": "^8.8.1",
    "@emotion/react": "^11.14.0",
    "@fluentui/react-components": "^9.73.7",
    "@microsoft/applicationinsights-react-js": "^19.3.8",
    "@microsoft/applicationinsights-web": "^3.3.11",
    "@microsoft/teams-js": "2.51.0",
    "axios": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "react-intl": "^10.1.1",
    "react-router-dom": "^7.14.0",
    "react-use": "^17.6.0",
    "ress": "^5.0.2"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@formatjs/cli": "^6.14.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-formatjs": "^11.3.2",
    "eslint": "^9.39.4",
    "eslint-plugin-hooks": "^0.4.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "postcss-styled-syntax": "^0.7.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  }
}
