{
  "ApplicationInsights": {
    "ConnectionString": "InstrumentationKey=00000000-0000-0000-0000-000000000000",
    "EnableAdaptiveSampling": false,
    "EnableDependencyTrackingTelemetryModule": false,
    "EnablePerformanceCounterCollectionModule": false
  },
  "AzureStorageBlobs": {
    "ContainerName": "{{AZURE_STORAGE_BLOBS_CONTAINER_NAME}}",
    "Endpoint": "{{AZURE_STORAGE_BLOBS_ENDPOINT}}"
  },
  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "ClientId": "{{MICROSOFT_365_AGENT_ID}}",
        "ClientSecret": "{{MICROSOFT_365_AGENT_PASSWORD}}",
        "Scopes": [
          "https://api.botframework.com/.default"
        ],
        "TenantId": "{{MICROSOFT_365_AGENT_TENANT_ID}}"
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],
  "ConnectorClient": {
    "Audience": "https://api.botframework.com/",
    "ClientId": "{{MICROSOFT_365_AGENT_ID}}"
  },
  "Logging": {
    "ApplicationInsights": {
      "LogLevel": {
        "Azure": "Error",
        "Default": "Information",
        "Microsoft": "Error",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "LogLevel": {
      "Azure": "Error",
      "Default": "Information",
      "Microsoft": "Error",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "MicrosoftIdentity": {
    "ClientId": "{{MICROSOFT_365_AGENT_ID}}",
    "ClientSecret": "{{MICROSOFT_365_AGENT_PASSWORD}}",
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "{{MICROSOFT_365_AGENT_TENANT_ID}}"
  }
}
